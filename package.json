{
  "name": "wechat-codex-bridge",
  "version": "0.1.0",
  "description": "A WeChat bridge daemon for controlling the local Codex CLI.",
  "type": "module",
  "bin": {
    "wechat-codex-bridge": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "setup": "tsx src/main.ts setup",
    "start": "tsx src/main.ts start",
    "daemon": "tsx src/main.ts daemon"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.17",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
